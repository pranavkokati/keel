# ── Keel environment configuration ──────────────────────────────────────────
# Keel is BYOK for AI inference: end users paste their own Groq / Gemini /
# OpenRouter key into the in-app Settings panel. Those keys are NEVER put in
# this file and never touch this server's disk or logs — see
# src/lib/byok/keyStore.js and api/relay.js.
#
# Everything below is infrastructure the OPERATOR (you, if you're running a
# hosted instance) provides on free tiers. If you're just running Keel
# locally for yourself, you can skip Supabase/E2B and use local-only mode.

# Supabase (auth + saved projects + usage ledger). Free tier project at
# https://supabase.com/dashboard — see supabase/migrations/0001_init.sql.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# E2B (sandbox preview). Free Hobby tier at https://e2b.dev/dashboard —
# 100 hours/month. KEEL_SANDBOX_MONTHLY_HOUR_CAP enforces a hard stop in
# src/lib/sandbox/killSwitch.js so usage can never silently roll into billing.
E2B_API_KEY=
KEEL_SANDBOX_MONTHLY_HOUR_CAP=90

# Direct Postgres connection string for backend auto-provisioning (Supabase
# dashboard -> Project Settings -> Database -> Connection string). This is
# NOT the same as SUPABASE_SERVICE_ROLE_KEY — PostgREST (what the service
# role key talks to) can't run CREATE TABLE, only a real Postgres connection
# can. Used only by api/backend/provision.js, and only to run the narrow,
# allowlisted DDL validated in src/lib/generation/backendProvision.js. For
# defense in depth beyond that allowlist, point this at a scoped Postgres
# role rather than the project's postgres superuser connection string.
SUPABASE_DB_URL=

# Vercel API token (https://vercel.com/account/tokens) for the "Publish
# live" button — gives each generated app a real, permanent URL under the
# operator's own Vercel account instead of only a ZIP/sandbox preview.
# KEEL_DEPLOY_MONTHLY_CAP enforces a hard stop in
# src/lib/sandbox/deployKillSwitch.js so a busy instance can't run the
# operator into paid Vercel usage or abuse detection.
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
KEEL_DEPLOY_MONTHLY_CAP=200

# Optional: web-search augmentation for generation (operator-provided,
# separate from each user's BYOK model key). Free tiers available from
# Tavily / Serper.
TAVILY_API_KEY=
